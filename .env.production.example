# =====================================================================
#  Plantilla de variables de entorno — PRODUCCIÓN (Docker)
#  Copiá este archivo a ".env" en el server y completá los valores reales.
#  El ".env" NO debe versionarse (está en .gitignore) ni hornearse en la
#  imagen (está en .dockerignore). docker-compose lo inyecta vía env_file.
# =====================================================================

# --- Base de datos MySQL EXTERNA ---
# Si la DB vive en el mismo host que Docker: host.docker.internal (ya mapeado en compose).
# Si es un server/IP aparte: poné su hostname o IP.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=facturas_app
DB_PASSWORD=__cambiar__
DB_NAME=facturas_afip

# --- Entorno AFIP ---
AFIP_MODO=produccion           # requiere certificados y delegaciones de PRODUCCIÓN
AFIP_CACHE_DIR=./.afip_cache

# --- Seguridad de la app web ---
# Generar una clave nueva: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__generar_clave_larga_aleatoria__
SESSION_MAX_AGE=43200

# --- Rutas (relativas a /app; NO cambiar, calzan con los volúmenes del compose) ---
CERTS_DIR=./certs
PDFS_DIR=./pdfs
LOG_DIR=./logs

# --- Usuario administrador inicial (init_db.py) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=danielgustavo80@gmail.com
ADMIN_PASSWORD=__cambiar__
