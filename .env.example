# =====================================================================
#  Plantilla de variables de entorno — Sistema de Facturación AFIP
#  Copiá este archivo a ".env" y completá los valores reales.
#  El archivo ".env" NO debe versionarse (está en .gitignore).
# =====================================================================

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sghx486
DB_NAME=facturas_afip

# --- Entorno AFIP ---
# homologacion = entorno de pruebas (SIN validez fiscal). Usar SIEMPRE primero.
# produccion   = comprobantes con validez fiscal real.
AFIP_MODO=homologacion

# Carpeta donde pyafipws cachea el Ticket de Acceso (TA, válido ~12 h).
AFIP_CACHE_DIR=./.afip_cache

# --- Seguridad de la app web ---
# Generá una clave larga y aleatoria, por ejemplo con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_ALEATORIA
SESSION_MAX_AGE=43200             # duración de la sesión web en segundos (12 h)

# --- Rutas de almacenamiento (relativas a la raíz del proyecto) ---
CERTS_DIR=./certs                 # certificados .crt/.key por empresa
PDFS_DIR=./pdfs                   # PDFs de comprobantes emitidos
LOG_DIR=./logs                    # archivos de log

# --- Datos del usuario administrador inicial (usados por scripts/init_db.py) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=cambiar_esta_clave
